{
  "projects": [
    {
      "id": "my-app",
      "name": "my-app",
      "kind": "git",
      "url": "git@github.com:org/my-app.git",
      "branch": "main"
    },
    {
      "id": "legacy-local",
      "name": "legacy-local",
      "kind": "local",
      "path": "/path/to/local/checkout"
    }
  ],
  "defaultProjectId": "my-app"
}
