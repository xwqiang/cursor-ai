CURSOR_API_KEY=crsr_xxx
TELEGRAM_BOT_TOKEN=0000000000:telegram-bot-token
TG_DEBUG=true
CURSOR_MODEL=auto
CURSOR_ADVANCED_MODEL=claude-opus-4-6

# 管理员用户 ID（逗号分隔），只有管理员可以触发代码修改
TG_ADMIN_IDS=123456789

# --- 目标项目（二选一，Git 优先）---
# 方式一（推荐，服务器部署）：GitHub 远程仓库，首次启动自动 clone 到 data/repos/<id>/
PROJECT_GIT_URL=git@github.com:org/my-app.git
PROJECT_GIT_BRANCH=main
# PROJECT_ID=my-app
# PROJECT_NAME=my-app

# 方式二：本地目录（开发机已有 checkout 时用）
# PROJECT_ROOT=/path/to/your/project

# MCP 白名单由项目 .cursor/mcp.json 定义；可按需在 data/projects.json 的 mcpServers 字段进一步限定
# 启动时粗测各 MCP 子进程能否拉起（非测 MySQL 连通）
TG_MCP_STARTUP_PROBE=true

# MCP 使用提示（JSON 格式），不设则用内置默认
# TG_MCP_HINTS={"ssh-mcp":"SSH 远程执行","redis":"Redis 缓存"}

# --- 多项目管理 ---
# 单项目：首次 ./start.sh 会按上方 env 自动生成 data/projects.json
# 多项目：cp data/projects.json.example data/projects.json 后编辑
# 群→项目绑定由 Bot 自动写入 data/chat-projects.json（/projects 切换时）
# 也可通过 Bot 命令动态管理：/project add local|git ...
# Git 仓库认证依赖宿主机已配置的 SSH key 或 HTTPS credential helper
# 详见 docs/projects.md
